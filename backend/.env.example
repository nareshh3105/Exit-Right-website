APP_NAME="EXIT RIGHT API"
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT=8000

# Supabase pooled connection string (recommended for production)
# Note: use postgresql+asyncpg:// prefix, NOT postgres://
DATABASE_URL="postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be >= 32 chars in production
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_EXP_MINUTES=1440

# Routing — OpenRouteService (free, no credit card required)
# Sign up at: https://openrouteservice.org/dev/#/signup
# Leave blank to use built-in heuristic travel-time estimates (still works)
OPENROUTESERVICE_API_KEY=""

# Weather — OpenWeatherMap (free tier, no credit card)
# Sign up at: https://openweathermap.org/api
# Leave blank to default to "Clear" weather (still works)
OPENWEATHER_API_KEY=""

# CORS
FRONTEND_BASE_URL="http://localhost:3000"
# Comma-separated additional allowed origins (e.g. staging URL)
CORS_ALLOW_ORIGINS=""

# Sentry error tracking — leave blank to disable
SENTRY_DSN=""
